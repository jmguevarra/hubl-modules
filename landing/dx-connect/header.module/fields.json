      {
        "id": "nav_style",
        "name": "nav_style",
        "label": "Navigation",
        "type": "group",
        "children": [
          {
            "id": "nav_text_color",
            "name": "nav_text_color",
            "label": "Link Color",
            "type": "color",
            "default": {
              "color": "#FFFFFF",
              "opacity": 100
            }
          }
        ]
      },
      {
        "id": "button_style",
        "name": "button_style",
        "label": "Button",
        "type": "group",
        "children": [
          {
            "id": "button_text_color",
            "name": "button_text_color",
            "label": "Text Color",
            "type": "color",
            "default": {
              "color": "#0A0A1A",
              "opacity": 100
            }
          },
          {
            "id": "bg_type",
            "name": "bg_type",
            "label": "Background Type",
            "type": "choice",
            "display": "radio",
            "choices": [
              ["solid", "Solid"],
              ["gradient", "Gradient"]
            ],
            "default": "solid"
          },
          {
            "id": "button_bg_color",
            "name": "button_bg_color",
            "label": "Background Color",
            "type": "color",
            "default": {
              "color": "#C9A84C",
              "opacity": 100
            },
            "visibility": {
              "controlling_field_path": "styles.button_style.bg_type",
              "operator": "EQUAL",
              "controlling_value_regex": "solid"
            }
          },
          {
            "id": "gradient_start",
            "name": "gradient_start",
            "label": "Gradient Start Color",
            "type": "color",
            "default": {
              "color": "#C9A84C",
