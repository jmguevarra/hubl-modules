    "children": [
      {
        "id": "nav_label",
        "name": "nav_label",
        "label": "Label",
        "type": "text",
        "default": "The Experience"
      },
      {
        "id": "nav_url",
        "name": "nav_url",
        "label": "URL",
        "type": "url",
        "default": ""
      },
      {
        "id": "nav_new_tab",
        "name": "nav_new_tab",
        "label": "Open in New Tab",
        "type": "boolean",
        "default": false
      }
    ]
  },
  {
    "id": "button_section",
    "name": "button_section",
    "label": "Button",
    "type": "group",
    "children": [
      {
        "id": "button_text",
        "name": "button_text",
        "label": "Button Text",
        "type": "text",
        "default": "REQUEST YOUR SEAT"
      },
      {
        "id": "button_url",
        "name": "button_url",
        "label": "Button URL",
