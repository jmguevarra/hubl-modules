          },
          {
            "id": "bg_type",
            "name": "bg_type",
            "label": "Background Type",
            "type": "choice",
            "display": "radio",
            "choices": [
              ["solid", "Solid"],
              ["gradient", "Gradient"]
            ],
            "default": "solid"
          },
          {
            "id": "button_bg_color",
            "name": "button_bg_color",
            "label": "Background Color",
            "type": "color",
            "default": {
              "color": "#C9A84C",
              "opacity": 100
            },
            "visibility": {
              "controlling_field_path": "colors.button_style.bg_type",
              "operator": "EQUAL",
              "controlling_value_regex": "solid"
            }
          },
          {
            "id": "gradient_start",
            "name": "gradient_start",
            "label": "Gradient Start Color",
            "type": "color",
            "default": {
              "color": "#C9A84C",
              "opacity": 100
            },
            "visibility": {
              "controlling_field_path": "colors.button_style.bg_type",
              "operator": "EQUAL",
              "controlling_value_regex": "gradient"
