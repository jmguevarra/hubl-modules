[
  {
    "id": "top_text",
    "name": "top_text",
    "label": "Top Text",
    "type": "text",
    "default": "THE EXPERIENCE"
  },
  {
    "id": "heading",
    "name": "heading",
    "label": "Heading",
    "type": "text",
    "default": "Where world-class thinking meets candid peer conversation"
  },
  {
    "id": "content",
    "name": "content",
    "label": "Content",
    "type": "richtext",
    "default": "<p>The agentic AI revolution is already creating an accelerating gap between organisations that act now and those that wait.</p>"
  },
  {
    "id": "cards",
    "name": "cards",
    "label": "Cards",
    "type": "group",
    "occurrence": {
      "min": 1,
      "max": 8,
      "default": 4,
      "sorting_label_field": "stat_number"
    },
    "children": [
      {
        "id": "card_type",
        "name": "card_type",
        "label": "Card Type",
        "type": "choice",
        "display": "radio",
        "choices": [
          ["stat", "Stat"],
          ["event", "Event"]
        ],
        "default": "stat"
      },
      {
        "id": "stat_number",
        "name": "stat_number",
        "label": "Stat Number",
        "type": "text",
        "default": "75",
        "visibility": {
          "controlling_field_path": "cards.card_type",
          "operator": "EQUAL",
          "controlling_value_regex": "stat"
        }
      },
      {
        "id": "stat_label",
        "name": "stat_label",
        "label": "Stat Label",
        "type": "text",
        "default": "LEADERS ACROSS APAC",
        "visibility": {
          "controlling_field_path": "cards.card_type",
          "operator": "EQUAL",
          "controlling_value_regex": "stat"
        }
      },
      {
        "id": "event_location",
        "name": "event_location",
        "label": "Event Location",
        "type": "text",
        "default": "SYDNEY & MELBOURNE",
        "visibility": {
          "controlling_field_path": "cards.card_type",
          "operator": "EQUAL",
          "controlling_value_regex": "event"
        }
      },
      {
        "id": "event_date",
        "name": "event_date",
        "label": "Event Date",
        "type": "text",
        "default": "19 August 2026",
        "visibility": {
          "controlling_field_path": "cards.card_type",
          "operator": "EQUAL",
          "controlling_value_regex": "event"
        }
      },
      {
        "id": "event_details",
        "name": "event_details",
        "label": "Event Details",
        "type": "text",
        "default": "Lunch · 12 – 2 PM",
        "visibility": {
          "controlling_field_path": "cards.card_type",
          "operator": "EQUAL",
          "controlling_value_regex": "event"
        }
      }
    ]
  },
