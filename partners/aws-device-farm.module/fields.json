[
  {
    "id": "partner_logo",
    "name": "partner_logo",
    "label": "Partner Logo",
    "type": "image",
    "default": {
      "src": "",
      "alt": "Partner logo",
      "width": 120,
      "height": 80
    }
  },
  {
    "id": "show_divider",
    "name": "show_divider",
    "label": "Show Divider",
    "type": "boolean",
    "default": true
  },
  {
    "id": "product_logo",
    "name": "product_logo",
    "label": "Product Logo",
    "type": "image",
    "default": {
      "src": "",
      "alt": "Product logo",
      "width": 64,
      "height": 64
    }
  },
  {
    "id": "product_name",
    "name": "product_name",
    "label": "Product Name",
    "type": "text",
    "default": "AWS Device Farm"
  },
  {
    "id": "description",
    "name": "description",
    "label": "Description",
    "type": "richtext",
    "default": "<p>An application testing service that lets you improve mobile app quality by testing them across a range of desktop browsers and real mobile devices.</p>"
  },
  {
    "id": "styles",
    "name": "styles",
    "label": "Styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "id": "section_style",
        "name": "section_style",
        "label": "Section",
        "type": "group",
        "children": [
          {
            "id": "enable_section_styles",
            "name": "enable_section_styles",
            "label": "Enable Section Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "section_style_fields",
            "name": "section_style_fields",
            "label": "Section Style Options",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.section_style.enable_section_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "section_bg_color",
                "name": "section_bg_color",
                "label": "Background Color",
                "type": "color",
                "default": {
                  "color": "#F5F5F5",
                  "opacity": 100
                }
              }
            ]
          }
        ]
      },
      {
        "id": "title_style",
        "name": "title_style",
        "label": "Title",
        "type": "group",
        "children": [
          {
            "id": "enable_title_styles",
            "name": "enable_title_styles",
            "label": "Enable Title Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "title_style_fields",
            "name": "title_style_fields",
            "label": "Title Style Options",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.title_style.enable_title_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "title_color",
                "name": "title_color",
                "label": "Text Color",
                "type": "color",
                "default": {
                  "color": "#0A0A1A",
                  "opacity": 100
                }
              },
              {
                "id": "title_font_size",
                "name": "title_font_size",
                "label": "Font Size",
                "type": "choice",
                "display": "select",
                "choices": [
                  ["12px", "12px"],
                  ["14px", "14px"],
                  ["16px", "16px"],
                  ["18px", "18px"],
                  ["20px", "20px"],
                  ["22px", "22px"],
                  ["24px", "24px"]
                ],
                "default": "16px"
              },
              {
                "id": "title_text_transform",
                "name": "title_text_transform",
                "label": "Text Transform",
                "type": "choice",
                "display": "radio",
                "choices": [
                  ["uppercase", "Uppercase"],
                  ["none", "None"]
                ],
                "default": "uppercase"
              }
            ]
          }
        ]
      },
      {
        "id": "description_style",
        "name": "description_style",
        "label": "Description",
        "type": "group",
        "children": [
          {
            "id": "enable_description_styles",
            "name": "enable_description_styles",
            "label": "Enable Description Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "description_style_fields",
            "name": "description_style_fields",
            "label": "Description Style Options",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.description_style.enable_description_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "description_color",
                "name": "description_color",
                "label": "Text Color",
                "type": "color",
                "default": {
                  "color": "#4A4A5A",
                  "opacity": 100
                }
              },
              {
                "id": "description_font_size",
                "name": "description_font_size",
                "label": "Font Size",
                "type": "choice",
                "display": "select",
                "choices": [
                  ["12px", "12px"],
                  ["13px", "13px"],
                  ["14px", "14px"],
                  ["15px", "15px"],
                  ["16px", "16px"]
                ],
                "default": "14px"
              }
            ]
          }
        ]
      }
    ]
  }
]
