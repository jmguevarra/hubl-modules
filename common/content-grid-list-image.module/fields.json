      {
        "id": "colors",
        "name": "colors",
        "label": "Colors",
        "type": "group",
        "children": [
          {
            "id": "enable_styles",
            "name": "enable_styles",
            "label": "Enable Custom Colors",
            "type": "boolean",
            "default": false
          },
          {
            "id": "style_fields",
            "name": "style_fields",
            "label": "Color Options",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.colors.enable_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "bg_color",
                "name": "bg_color",
                "label": "Background Color",
                "type": "color",
                "default": { "color": "#FFFFFF", "opacity": 100 }
