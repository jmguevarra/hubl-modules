[
  {
    "id": "heading",
    "name": "heading",
    "label": "Heading",
    "type": "text",
    "default": "What we offer"
  },
  {
    "id": "heading_tag",
    "name": "heading_tag",
    "label": "Heading Tag",
    "type": "choice",
    "display": "select",
    "choices": [
      ["h1", "H1"],
      ["h2", "H2"],
      ["h3", "H3"],
      ["h4", "H4"]
    ],
    "default": "h2"
  },
  {
    "id": "description",
    "name": "description",
    "label": "Description (optional)",
    "type": "richtext",
    "default": ""
  },
  {
    "id": "items",
    "name": "items",
    "label": "List Items",
    "type": "group",
    "occurrence": {
      "min": 1,
      "max": 20,
      "default": 4,
      "sorting_label_field": "text"
    },
    "children": [
      {
        "id": "item_icon",
        "name": "item_icon",
        "label": "Custom Icon (optional)",
        "type": "image",
        "default": {
          "src": "",
          "alt": "",
          "width": 20,
          "height": 20
        }
      },
      {
        "id": "item_text",
        "name": "item_text",
        "label": "Item Text",
        "type": "text",
        "default": "List item text"
      }
    ]
  },
  {
    "id": "side_images",
    "name": "side_images",
    "label": "Side Images / Badges",
