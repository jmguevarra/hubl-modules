          },
          {
            "id": "spacing_mobile",
            "name": "spacing_mobile",
            "label": "Mobile",
            "type": "group",
            "children": [
              {
                "id": "mobile_spacing",
                "name": "mobile_spacing",
                "label": "Spacing",
                "type": "spacing"
              }
            ]
          }
        ]
      },
      {
