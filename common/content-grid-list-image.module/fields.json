          {
            "id": "image_alignment",
            "name": "image_alignment",
            "label": "Image Vertical Alignment",
            "type": "choice",
            "display": "select",
            "choices": [
              ["start", "Top"],
              ["center", "Center"],
              ["end", "Bottom"]
