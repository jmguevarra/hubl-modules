              {
                "id": "heading_color",
                "name": "heading_color",
                "label": "Heading Color",
                "type": "color",
                "default": { "color": "#1A1A2E", "opacity": 100 }
              },
              {
                "id": "text_color",
                "name": "text_color",
                "label": "Text Color",
                "type": "color",
                "default": { "color": "#333333", "opacity": 100 }
              },
              {
                "id": "icon_color",
                "name": "icon_color",
                "label": "Icon Color",
                "type": "color",
                "default": { "color": "#E8264C", "opacity": 100 }
              }
            ]
          }
        ]
      }
