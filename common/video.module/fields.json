[
  {
    "id": "video_type",
    "name": "video_type",
    "label": "Video Type",
    "type": "choice",
    "display": "select",
    "choices": [
      ["hubspot", "HubSpot Video"],
      ["url", "URL (YouTube / Vimeo)"],
      ["embed", "Embed Code"]
    ],
    "default": "hubspot"
  },
  {
    "id": "hs_video",
    "name": "hs_video",
    "label": "HubSpot Video",
    "type": "videoplayer",
    "show_advanced_options": false,
    "visibility": {
      "controlling_field_path": "video_type",
      "operator": "EQUAL",
      "controlling_value_regex": "hubspot"
    }
  },
  {
    "id": "video_url",
    "name": "video_url",
    "label": "Video URL",
    "help_text": "Paste the embed URL. YouTube: https://www.youtube.com/embed/ID — Vimeo: https://player.vimeo.com/video/ID",
    "type": "text",
    "default": "",
    "visibility": {
      "controlling_field_path": "video_type",
      "operator": "EQUAL",
      "controlling_value_regex": "url"
    }
  },
  {
    "id": "embed_code",
    "name": "embed_code",
    "label": "Embed Code",
    "help_text": "Paste your full iframe embed code here (e.g. from Vimeo, YouTube, or any other platform).",
    "type": "text",
    "default": "",
    "visibility": {
      "controlling_field_path": "video_type",
      "operator": "EQUAL",
      "controlling_value_regex": "embed"
    }
  },
  {
    "id": "caption",
    "name": "caption",
    "label": "Caption",
    "help_text": "Optional text shown below the video",
    "type": "text",
    "default": ""
  },
  {
    "id": "styles",
    "name": "styles",
    "label": "Styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "id": "desktop",
        "name": "desktop",
        "label": "Desktop",
        "type": "group",
        "children": [
          {
            "id": "desktop_alignment",
            "name": "desktop_alignment",
            "label": "Alignment",
            "type": "alignment",
            "alignment_direction": "HORIZONTAL",
            "default": {
              "horizontal_align": "CENTER"
            }
          },
          {
            "id": "desktop_max_width",
            "name": "desktop_max_width",
            "label": "Max Width (px)",
            "help_text": "Set to 0 for full width",
            "type": "number",
            "min": 0,
            "max": 2560,
            "default": 0
          },
          {
            "id": "desktop_spacing",
            "name": "desktop_spacing",
            "label": "Spacing",
            "type": "spacing"
          }
        ]
      },
      {
        "id": "tablet",
        "name": "tablet",
        "label": "Tablet  (≤ 1024px)",
        "type": "group",
        "children": [
          {
            "id": "tablet_alignment",
            "name": "tablet_alignment",
            "label": "Alignment",
            "type": "alignment",
            "alignment_direction": "HORIZONTAL",
            "default": {
              "horizontal_align": "CENTER"
            }
          },
          {
            "id": "tablet_max_width",
            "name": "tablet_max_width",
            "label": "Max Width (px)",
            "help_text": "Set to 0 for full width",
            "type": "number",
            "min": 0,
            "max": 1024,
            "default": 0
          },
          {
            "id": "tablet_spacing",
            "name": "tablet_spacing",
            "label": "Spacing",
            "type": "spacing"
          }
        ]
      },
      {
        "id": "mobile",
        "name": "mobile",
        "label": "Mobile  (≤ 767px)",
        "type": "group",
        "children": [
          {
            "id": "mobile_alignment",
            "name": "mobile_alignment",
            "label": "Alignment",
            "type": "alignment",
            "alignment_direction": "HORIZONTAL",
            "default": {
              "horizontal_align": "CENTER"
            }
          },
          {
            "id": "mobile_max_width",
            "name": "mobile_max_width",
            "label": "Max Width (px)",
            "help_text": "Set to 0 for full width",
            "type": "number",
            "min": 0,
            "max": 767,
            "default": 0
          },
          {
            "id": "mobile_spacing",
            "name": "mobile_spacing",
            "label": "Spacing",
            "type": "spacing"
          }
        ]
      }
    ]
  }
]
