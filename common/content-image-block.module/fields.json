[
  {
    "id": "layout",
    "name": "layout",
    "label": "Layout",
    "type": "choice",
    "display": "select",
    "choices": [
      ["content-image", "Content | Image"],
      ["image-content", "Image | Content"]
    ],
    "default": "content-image"
  },
  {
    "id": "top_text",
    "name": "top_text",
    "label": "Top Text",
    "type": "text",
    "default": ""
  },
  {
    "id": "heading",
    "name": "heading",
    "label": "Heading",
    "type": "text",
    "default": "Section Heading"
  },
  {
    "id": "content",
    "name": "content",
    "label": "Content",
    "type": "richtext",
    "default": "<p>Add your content here.</p>"
  },
  {
    "id": "button_section",
    "name": "button_section",
    "label": "Button",
    "type": "group",
    "children": [
      {
        "id": "button_text",
        "name": "button_text",
        "label": "Button Text",
        "type": "text",
        "default": ""
      },
      {
        "id": "button_type",
        "name": "button_type",
        "label": "Button Type",
        "type": "choice",
        "display": "select",
        "choices": [
          ["link", "Link"],
          ["anchor", "Anchor"]
        ],
        "default": "link"
      },
      {
        "id": "button_url",
        "name": "button_url",
        "label": "Button URL",
        "type": "url",
        "default": "",
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "link"
        }
      },
      {
        "id": "button_new_tab",
        "name": "button_new_tab",
        "label": "Open in New Tab",
        "type": "boolean",
        "default": false,
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "link"
        }
      },
      {
        "id": "button_anchor",
        "name": "button_anchor",
        "label": "Anchor ID",
        "type": "text",
        "default": "",
        "help_text": "Enter the section anchor ID to scroll to, e.g. #form-section",
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "anchor"
        }
      }
    ]
  },
  {
    "id": "image",
    "name": "image",
    "label": "Image",
    "type": "image",
    "default": {
      "src": "",
      "alt": "",
      "width": 600,
      "height": 500
    }
  },
  {
    "id": "styles",
    "name": "styles",
    "label": "Styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "id": "colors",
        "name": "colors",
        "label": "Colors",
        "type": "group",
        "children": [
          {
            "id": "enable_color_styles",
            "name": "enable_color_styles",
            "label": "Enable Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "section_bg_color",
            "name": "section_bg_color",
            "label": "Section Background",
            "type": "color",
            "default": { "color": "#ffffff", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "top_text_color",
            "name": "top_text_color",
            "label": "Top Text Color",
            "type": "color",
            "default": { "color": "#0A0A1A", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "heading_color",
            "name": "heading_color",
            "label": "Heading Color",
            "type": "color",
            "default": { "color": "#0A0A1A", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "content_color",
            "name": "content_color",
            "label": "Content Color",
            "type": "color",
            "default": { "color": "#333333", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          }
        ]
      },
      {
        "id": "button_style",
        "name": "button_style",
        "label": "Button Style",
        "type": "choice",
        "display": "select",
        "choices": [
          ["primary", "Primary"],
          ["secondary", "Secondary"],
          ["blog", "Blog"],
          ["training", "Training"],
          ["blog-hover-fill", "Blog Hover-Fill"],
          ["training-hover-fill", "Training Hover-Fill"],
          ["primary-outline", "Primary Outline"],
          ["secondary-outline", "Secondary Outline"],
          ["tertiary-outline", "Tertiary Outline"]
        ],
        "default": "primary"
      }
    ]
  }
]
