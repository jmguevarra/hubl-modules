[
  {
    "id": "layout",
    "name": "layout",
    "label": "Layout",
    "type": "choice",
    "display": "select",
    "choices": [
      ["content-image", "Content | Image"],
      ["image-content", "Image | Content"]
    ],
    "default": "content-image"
  },
  {
    "id": "top_text",
    "name": "top_text",
    "label": "Top Text",
    "type": "text",
    "default": ""
  },
  {
    "id": "heading",
    "name": "heading",
    "label": "Heading",
    "type": "text",
    "default": "Section Heading"
  },
  {
    "id": "content",
    "name": "content",
    "label": "Content",
    "type": "richtext",
    "default": "<p>Add your content here.</p>"
  },
  {
    "id": "button_section",
    "name": "button_section",
    "label": "Button",
    "type": "group",
    "children": [
      {
        "id": "button_text",
        "name": "button_text",
        "label": "Button Text",
        "type": "text",
        "default": ""
      },
      {
        "id": "button_type",
        "name": "button_type",
        "label": "Button Type",
        "type": "choice",
        "display": "select",
        "choices": [
          ["link", "Link"],
          ["anchor", "Anchor"]
        ],
        "default": "link"
      },
      {
        "id": "button_url",
        "name": "button_url",
        "label": "Button URL",
        "type": "url",
        "default": "",
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "link"
        }
      },
      {
        "id": "button_new_tab",
        "name": "button_new_tab",
        "label": "Open in New Tab",
        "type": "boolean",
        "default": false,
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "link"
        }
      },
      {
        "id": "button_anchor",
        "name": "button_anchor",
        "label": "Anchor ID",
        "type": "text",
        "default": "",
        "help_text": "Enter the section anchor ID to scroll to, e.g. #form-section",
        "visibility": {
          "controlling_field_path": "button_section.button_type",
          "operator": "EQUAL",
          "controlling_value_regex": "anchor"
        }
      }
    ]
  },
  {
    "id": "image",
    "name": "image",
    "label": "Image",
    "type": "image",
    "default": {
      "src": "",
      "alt": "",
      "width": 600,
      "height": 500
    }
  },
  {
    "id": "styles",
    "name": "styles",
    "label": "Styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "id": "colors",
        "name": "colors",
        "label": "Colors",
        "type": "group",
        "children": [
          {
            "id": "enable_color_styles",
            "name": "enable_color_styles",
            "label": "Enable Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "section_bg_color",
            "name": "section_bg_color",
            "label": "Section Background",
            "type": "color",
            "default": { "color": "#ffffff", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "top_text_color",
            "name": "top_text_color",
            "label": "Top Text Color",
            "type": "color",
            "default": { "color": "#0A0A1A", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "heading_color",
            "name": "heading_color",
            "label": "Heading Color",
            "type": "color",
            "default": { "color": "#0A0A1A", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          },
          {
            "id": "content_color",
            "name": "content_color",
            "label": "Content Color",
            "type": "color",
            "default": { "color": "#333333", "opacity": 100 },
            "visibility": {
              "controlling_field_path": "styles.colors.enable_color_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            }
          }
        ]
      },
      {
        "id": "button_style",
        "name": "button_style",
        "label": "Button",
        "type": "group",
        "children": [
          {
            "id": "enable_styles",
            "name": "enable_styles",
            "label": "Enable Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "enable_hover",
            "name": "enable_hover",
            "label": "Enable Hover Styles",
            "type": "boolean",
            "default": false
          },
          {
            "id": "style_fields",
            "name": "style_fields",
            "label": "Style Options",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.button_style.enable_styles",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "button_text_color",
                "name": "button_text_color",
                "label": "Text Color",
                "type": "color",
                "default": { "color": "#0A0A1A", "opacity": 100 }
              },
              {
                "id": "bg_type",
                "name": "bg_type",
                "label": "Background Type",
                "type": "choice",
                "display": "radio",
                "choices": [["solid", "Solid"], ["gradient", "Gradient"]],
                "default": "solid"
              },
              {
                "id": "button_bg_color",
                "name": "button_bg_color",
                "label": "Background Color",
                "type": "color",
                "default": { "color": "#C9A84C", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.style_fields.bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "solid"
                }
              },
              {
                "id": "gradient_start",
                "name": "gradient_start",
                "label": "Gradient Start Color",
                "type": "color",
                "default": { "color": "#C9A84C", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.style_fields.bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              },
              {
                "id": "gradient_end",
                "name": "gradient_end",
                "label": "Gradient End Color",
                "type": "color",
                "default": { "color": "#E8C96A", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.style_fields.bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              },
              {
                "id": "gradient_direction",
                "name": "gradient_direction",
                "label": "Gradient Direction",
                "type": "choice",
                "default": "to right",
                "choices": [
                  ["to right", "Left → Right"],
                  ["to left", "Right → Left"],
                  ["to bottom", "Top → Bottom"],
                  ["to top", "Bottom → Top"],
                  ["to bottom right", "Top Left → Bottom Right"],
                  ["to bottom left", "Top Right → Bottom Left"]
                ],
                "visibility": {
                  "controlling_field_path": "styles.button_style.style_fields.bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              }
            ]
          },
          {
            "id": "hover_styles",
            "name": "hover_styles",
            "label": "Hover Styles",
            "type": "group",
            "visibility": {
              "controlling_field_path": "styles.button_style.enable_hover",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "children": [
              {
                "id": "hover_text_color",
                "name": "hover_text_color",
                "label": "Text Color",
                "type": "color",
                "default": { "color": "#0A0A1A", "opacity": 100 }
              },
              {
                "id": "hover_bg_type",
                "name": "hover_bg_type",
                "label": "Background Type",
                "type": "choice",
                "display": "radio",
                "choices": [["solid", "Solid"], ["gradient", "Gradient"]],
                "default": "solid"
              },
              {
                "id": "hover_bg_color",
                "name": "hover_bg_color",
                "label": "Background Color",
                "type": "color",
                "default": { "color": "#A88A38", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.hover_styles.hover_bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "solid"
                }
              },
              {
                "id": "hover_gradient_start",
                "name": "hover_gradient_start",
                "label": "Gradient Start Color",
                "type": "color",
                "default": { "color": "#A88A38", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.hover_styles.hover_bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              },
              {
                "id": "hover_gradient_end",
                "name": "hover_gradient_end",
                "label": "Gradient End Color",
                "type": "color",
                "default": { "color": "#C9A84C", "opacity": 100 },
                "visibility": {
                  "controlling_field_path": "styles.button_style.hover_styles.hover_bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              },
              {
                "id": "hover_gradient_direction",
                "name": "hover_gradient_direction",
                "label": "Gradient Direction",
                "type": "choice",
                "default": "to right",
                "choices": [
                  ["to right", "Left → Right"],
                  ["to left", "Right → Left"],
                  ["to bottom", "Top → Bottom"],
                  ["to top", "Bottom → Top"],
                  ["to bottom right", "Top Left → Bottom Right"],
                  ["to bottom left", "Top Right → Bottom Left"]
                ],
                "visibility": {
                  "controlling_field_path": "styles.button_style.hover_styles.hover_bg_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "gradient"
                }
              }
            ]
          }
        ]
      }
    ]
  }
]
