    "type": "text",
    "default": "PhoenixDX Stories"
  },
  {
    "id": "heading_tag",
    "name": "heading_tag",
    "label": "Heading Tag",
    "type": "choice",
    "display": "select",
    "choices": [
      ["h1", "H1"],
      ["h2", "H2"],
      ["h3", "H3"],
      ["h4", "H4"]
    ],
    "default": "h2"
  },
  {
    "id": "stories",
