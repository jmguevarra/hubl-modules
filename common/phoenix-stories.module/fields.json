        "label": "Name",
        "type": "text",
        "default": "Full Name"
      },
      {
        "id": "stories__job_title",
        "name": "job_title",
        "label": "Job Title",
        "type": "text",
        "default": ""
      },
      {
        "id": "stories__linkedin_url",
        "name": "linkedin_url",
        "label": "LinkedIn URL",
        "type": "link"
      },
      {
        "id": "stories__quote",
        "name": "quote",
        "label": "Quote",
        "help_text": "Short pull quote shown in italic at the top of the card",
        "type": "text",
        "default": ""
      },
      {
        "id": "stories__story_body",
        "name": "story_body",
        "label": "Body",
        "type": "richtext",
        "default": ""
